# Environment Variables Sample File
# Copy this file to .env and update the values with your actual configuration
# cp .env.sample .env

# =============================================================================
# SMART CONTRACT ADDRESSES
# =============================================================================
# These addresses are obtained from the backend deployment script
# They can be loaded dynamically from /shared/addresses.json (Docker) or set manually here

# UserAuth contract address
NEXT_PUBLIC_USER_AUTH_ADDRESS=

# BookCover contract address
NEXT_PUBLIC_BOOK_COVER_ADDRESS=

# Deployer account address (optional, for admin functions)
NEXT_PUBLIC_DEPLOYER_ADDRESS=


# =============================================================================
# IPFS CONFIGURATION
# =============================================================================
# For @helia/core and IPFS API connection
# Used for storing and retrieving book content, covers, and metadata

# IPFS API endpoint (used for uploads and direct API calls)
NEXT_PUBLIC_IPFS_API_URL=http://localhost:5001

# IPFS Gateway URL (used for accessing content via HTTP)
NEXT_PUBLIC_IPFS_GATEWAY=http://127.0.0.1:8080/ipfs/


# =============================================================================
# MONGODB CONFIGURATION
# =============================================================================
# For database connection and data storage

# MongoDB connection URI
# Format: mongodb://[username:password@]host[:port][/database]
MONGO_URI=mongodb://localhost:27017

# Database name to use
DB_NAME=bookstore


# =============================================================================
# DEPLOYMENT NOTES
# =============================================================================
# 
# DOCKER DEPLOYMENT:
# When running in Docker Compose, contract addresses are automatically loaded from
# /shared/addresses.json which is populated by the backend deployment script.
# You can leave the NEXT_PUBLIC_*_ADDRESS variables here as defaults - they will
# be overridden by the JSON file if it exists.
#
# DEVELOPMENT MODE:
# When running locally without Docker, copy the addresses from backend deployment
# output and paste them here. The frontend will use these values.
#
# PRODUCTION:
# Update all addresses with production values before deploying.
# Ensure IPFS and MongoDB connections point to production endpoints.
#
# =============================================================================
